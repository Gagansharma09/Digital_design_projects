module tb;
       logic clk;
       logic rst_n;
       logic [7:0]data_in;//8 bit data 
       logic tx_start;
       logic tx_busy;
       logic tx_done;
       logic tx;
  

   //dut 
  uart_tx dut(
        .clk      (clk),

        .rst_n    (rst_n),

        .data_in  (data_in),

        .tx_start (tx_start),

        .tx_busy  (tx_busy),

        .tx_done  (tx_done),

        .tx       (tx)
  );
   
        //clock gen 
       initial begin
         clk = 1'b0;
         forever #5 clk = ~clk;
       end 

       //initilaisation 
       initial begin 

         rst_n = 1'b0;

         repeat(2) @(posedge clk);

         rst_n = 1'b1;// active low

         repeat(2) @(posedge clk);

         data_in = 8'hA5;
         tx_start = 1'b1;
         @(posedge clk);

         tx_start = 1'b0;

         wait(tx_done);

         repeat(2) @(posedge clk);

         $finish;
       end 
  //displaying the values of tx (monitoring)
        initial begin 
          $monitor("time = %0t,tx = %b",$time,tx);
        end 
  //self checking testbench 
        initial begin 
          // Detect beginning of START bit

          @(negedge tx);

          // Move to middle of START bit

          repeat(10416/2) @(posedge clk);
          if(tx == 1'b0)//start bit has passes or not checking 
            $display("start BIT has passed");
          else 
            $display("start BIT has failed");
          //data transnfer checking 
          for (int i = 0;i < 8;i++)begin

            repeat(10416) @(posedge clk);

            if(tx == data_in[i])
              $display("data BIT %0d,data = %b",i,data_in[i]);
            else 
              $display("data BIT has failed");
          end 
            //stop bit checking 
            repeat(10416) @(posedge clk);
            if(tx == 1'b1)
              $display("stop bit has passed");
            else
              $display("stop bit has failed");
             
            //checking the trnasmision is complete or not 
            wait(tx_done);
            if(tx_done == 1'b1)
              $display("transmission is completed");
            else
              $display("transmission is incomplete");
          end 

          // assertions 
          property p_idle_tx;
            @(posedge clk)
            disable iff(!rst_n)
            (dut.state  == dut.IDLE) |-> (tx == 1'b1);
          endproperty 
          assert property (p_idle_tx)
             else $error("IDLE assertion failed");
          property p_start_tx;
            @(posedge clk)
            disable iff(!rst_n)
            (dut.state == dut.START) |-> (tx == 1'b0);
          endproperty 
          
            assert property (p_start_tx)
             else $error("START assertion failed");
             
          property p_data_tx;
            @(posedge clk)
            disable iff(!rst_n)
            (dut.state == dut.DATA) |-> (tx == dut.shifter[0]);
          endproperty 

              assert property (p_data_tx)
             else $error("DATA assertion failed");

          property p_stop_tx;
            @(posedge clk)
            disable iff(!rst_n)
            (dut.state == dut.STOP) |-> (tx == 1'b1);
          endproperty 

                assert property (p_stop_tx)
             else $error("STOP assertion failed");

endmodule 
