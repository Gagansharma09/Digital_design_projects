System clock — 100 MHz
set_property -dict { PACKAGE_PIN H16 IOSTANDARD LVCMOS33 } [get_ports clk]
create_clock -name sys_clk -period 10.000 [get_ports clk]

## Reset (active-low) — tie to button or pull-up
set_property -dict { PACKAGE_PIN D20 IOSTANDARD LVCMOS33 PULLUP true } [get_ports rst_n]

## Optional debug LEDs (map anomaly signals)
set_property -dict { PACKAGE_PIN L15 IOSTANDARD LVCMOS33 } [get_ports { outlier_any }]
set_property -dict { PACKAGE_PIN G17 IOSTANDARD LVCMOS33 } [get_ports { anomaly_pulse }]
set_property -dict { PACKAGE_PIN N15 IOSTANDARD LVCMOS33 } [get_ports { outlier_flags[0] }]
set_property -dict { PACKAGE_PIN G14 IOSTANDARD LVCMOS33 } [get_ports { outlier_flags[1] }]
set_property -dict { PACKAGE_PIN L14 IOSTANDARD LVCMOS33 } [get_ports { outlier_flags[2] }]
set_property -dict { PACKAGE_PIN M15 IOSTANDARD LVCMOS33 } [get_ports { outlier_flags[3] }]
